# Database (connection_limit and pool_timeout tune Prisma's connection pool)
DATABASE_URL=postgresql://lineforge:lineforge@localhost:5432/lineforge?connection_limit=10&pool_timeout=30
POSTGRES_PASSWORD=lineforge

# App
NODE_ENV=development
PORT=4000

# Auth
JWT_SECRET=dev-secret-change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Security
ALLOWED_ORIGINS=http://localhost:5173

# Frontend (Vite build-time vars)
VITE_API_URL=http://localhost:4000
VITE_GOOGLE_CLIENT_ID=
